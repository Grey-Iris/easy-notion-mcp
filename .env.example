NOTION_TOKEN=your_notion_integration_token_here
NOTION_ROOT_PAGE_ID=your_default_parent_page_id_here

# E2E test harness (optional — only needed for `npm run test:e2e`).
# Dedicate a throwaway Notion integration + a single parent page to automated
# E2E runs so they stay isolated from your day-to-day workspace. Each E2E run
# creates a fresh dated child under E2E_ROOT_PAGE_ID and archives it on
# teardown. Do NOT point this at pages with real content — runs are destructive
# by design.
E2E_ROOT_PAGE_ID=your_dedicated_e2e_parent_page_id_here
